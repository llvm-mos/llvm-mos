# NOTE: Assertions have been autogenerated by utils/update_mir_test_checks.py UTC_ARGS: --version 6
# RUN: llc -mtriple=mos -run-pass=greedy -verify-machineinstrs -o - %s | FileCheck %s

# Verify that MOS's shouldBlockClassRestrictingRemat override allows
# rematerialization of LDImm (which constrains to GPR) during live range
# splitting, despite getLargestLegalSuperClass inflating GPR to the
# disjoint union class Anyi8 (= GPR ∪ Imag8).
#
# Without the override, rematWillIncreaseRestriction would block remat
# because GPR is always a proper subclass of Anyi8, forcing expensive
# COPY/spill sequences instead of cheap immediate reloads.
---
name: remat_past_class_restriction
legalized: true
regBankSelected: true
tracksRegLiveness: true
body: |
  bb.0.entry:
    ; CHECK-LABEL: name: remat_past_class_restriction
    ; CHECK: JSR &fn, mos_csr
    ; CHECK-NEXT: [[LDImm:%[0-9]+]]:gpr = LDImm 42
    ; CHECK-NEXT: $a = COPY [[LDImm]]
    ; CHECK-NEXT: [[LDImm1:%[0-9]+]]:gpr = LDImm 99
    ; CHECK-NEXT: $x = COPY [[LDImm1]]
    ; CHECK-NEXT: RTS implicit $a, implicit $x
    %0:gpr = LDImm 42
    %1:gpr = LDImm 99
    JSR &fn, mos_csr
    $a = COPY %0
    $x = COPY %1
    RTS implicit $a, implicit $x
...
